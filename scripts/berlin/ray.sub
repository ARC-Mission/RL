#!/bin/bash
#SBATCH --job-name=ray_distillation
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=16
#SBATCH --gres=gpu:4
#SBATCH --mem=500G
#SBATCH --time=24:00:00
#SBATCH --partition=standard
#SBATCH --qos=low
#SBATCH --account=hfmi_synergyunit
#SBATCH --output=/fast/project/HFMI_SynergyUnit/yll/RL/scripts/logs/%j-%x.out

# Berlin bare-metal Ray launcher for NeMo-RL.
#
# Usage:
#   COMMAND="uv run python examples/run_distillation.py ..." \
#     GPUS_PER_NODE=4 sbatch scripts/berlin/ray.sub

set -euo pipefail

if [[ -n "${NEMO_DIR:-}" ]]; then
  REPO_ROOT="$NEMO_DIR"
elif REPO_ROOT="$(git -C "${SLURM_SUBMIT_DIR:-$PWD}" rev-parse --show-toplevel 2>/dev/null)"; then
  :
else
  echo "[ERROR] Could not determine repository root."
  echo "        Submit from inside the repo or set NEMO_DIR=/abs/path/to/RL."
  exit 1
fi
cd "$REPO_ROOT"

VENV="${UV_PROJECT_ENVIRONMENT:-$REPO_ROOT/.venv}"
export UV_PROJECT_ENVIRONMENT="$VENV"
export RAY_ENABLE_UV_RUN_RUNTIME_ENV="${RAY_ENABLE_UV_RUN_RUNTIME_ENV:-0}"

if [[ -x "$VENV/bin/ray" ]]; then
  RAY_BIN="$VENV/bin/ray"
elif command -v ray >/dev/null 2>&1; then
  RAY_BIN="$(command -v ray)"
else
  echo "[ERROR] ray binary not found in $VENV/bin/ray and not on PATH."
  exit 1
fi

if [[ -x "$VENV/bin/python" ]]; then
  PY_BIN="$VENV/bin/python"
elif command -v python >/dev/null 2>&1; then
  PY_BIN="$(command -v python)"
elif command -v python3 >/dev/null 2>&1; then
  PY_BIN="$(command -v python3)"
else
  echo "[ERROR] python interpreter not found in venv or PATH."
  exit 1
fi

LOG_DIR="${LOG_DIR:-$REPO_ROOT/scripts/logs/${SLURM_JOB_ID}-ray}"
mkdir -p "$LOG_DIR"

GPUS_PER_NODE="${GPUS_PER_NODE:-4}"
CPUS_PER_WORKER="${CPUS_PER_WORKER:-${SLURM_CPUS_PER_TASK:-16}}"
RAY_PORT="${RAY_PORT:-$((6379 + SLURM_JOB_ID % 1000))}"
RAY_DASHBOARD_PORT="${RAY_DASHBOARD_PORT:-$((8265 + SLURM_JOB_ID % 1000))}"

module purge
module load GCC/13.3.0
module load CUDA/12.6.0
module load git

# GCC module can set OMP_PROC_BIND=true, which crashes Ray's RuntimeEnvAgent.
unset OMP_PROC_BIND OMP_PLACES

export REPO_CACHE_ROOT="${REPO_CACHE_ROOT:-/fast/project/HFMI_SynergyUnit/yll/.cache}"
export JOB_CACHE_ROOT="${JOB_CACHE_ROOT:-$REPO_CACHE_ROOT/jobs/$SLURM_JOB_ID}"
export HF_HOME="${HF_HOME:-$REPO_CACHE_ROOT/huggingface}"
export CUDA_DEVICE_MAX_CONNECTIONS="${CUDA_DEVICE_MAX_CONNECTIONS:-1}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$JOB_CACHE_ROOT/xdg-cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$JOB_CACHE_ROOT/xdg-config}"
export NEMO_RL_VLLM_CACHE_BASE="${NEMO_RL_VLLM_CACHE_BASE:-$JOB_CACHE_ROOT/vllm}"
export NEMO_RL_VLLM_CONFIG_BASE="${NEMO_RL_VLLM_CONFIG_BASE:-$JOB_CACHE_ROOT/vllm-config}"
export TORCHINDUCTOR_CACHE_DIR="${TORCHINDUCTOR_CACHE_DIR:-$JOB_CACHE_ROOT/torch_inductor}"
export TRITON_CACHE_DIR="${TRITON_CACHE_DIR:-$JOB_CACHE_ROOT/triton}"
export FLASHINFER_CACHE_DIR="${FLASHINFER_CACHE_DIR:-$JOB_CACHE_ROOT/flashinfer}"
export TORCH_EXTENSIONS_DIR="${TORCH_EXTENSIONS_DIR:-$JOB_CACHE_ROOT/torch_extensions}"
export VLLM_NO_USAGE_STATS="${VLLM_NO_USAGE_STATS:-1}"
export VLLM_DO_NOT_TRACK="${VLLM_DO_NOT_TRACK:-1}"
export RAY_TMPDIR="${RAY_TMPDIR:-/tmp/${USER}/ray-${SLURM_JOB_ID}}"
export RAY_OBJECT_STORE_MEMORY="${RAY_OBJECT_STORE_MEMORY:-$((150 * 1024 * 1024 * 1024))}"
export RAY_OBJECT_STORE_ALLOW_SLOW_STORAGE="${RAY_OBJECT_STORE_ALLOW_SLOW_STORAGE:-1}"
export RAY_OVERRIDE_RESOURCES="{\"CPU\": $CPUS_PER_WORKER, \"GPU\": $GPUS_PER_NODE}"

if [[ -z "${TORCH_CUDA_ARCH_LIST:-}" ]]; then
  DETECTED_ARCH="$("$PY_BIN" - <<'PY' 2>/dev/null || true
import torch
if torch.cuda.is_available():
    major, minor = torch.cuda.get_device_capability(0)
    print(f"{major}.{minor}")
PY
)"
  if [[ -n "$DETECTED_ARCH" ]]; then
    export TORCH_CUDA_ARCH_LIST="$DETECTED_ARCH"
  else
    export TORCH_CUDA_ARCH_LIST="9.0"
  fi
fi
echo "[INFO] TORCH_CUDA_ARCH_LIST=$TORCH_CUDA_ARCH_LIST"

mkdir -p \
  "$RAY_TMPDIR" \
  "$HF_HOME" \
  "$XDG_CACHE_HOME" "$XDG_CONFIG_HOME" \
  "$NEMO_RL_VLLM_CACHE_BASE" "$NEMO_RL_VLLM_CONFIG_BASE" \
  "$TORCHINDUCTOR_CACHE_DIR" "$TRITON_CACHE_DIR" \
  "$FLASHINFER_CACHE_DIR" "$TORCH_EXTENSIONS_DIR"

if [[ $(ulimit -Hn) == "unlimited" ]] || [[ 65535 -lt $(ulimit -Hn) ]]; then
  ulimit -Sn 65535
fi

nodes=($(scontrol show hostnames "$SLURM_JOB_NODELIST"))
head_node="${nodes[0]}"
head_addr=""
declare -a SRUN_PIDS=()
TERMINATION_SIGNAL=""
DRIVER_RC=""

cleanup() {
  local rc=$?
  set +e
  if [[ -n "${TERMINATION_SIGNAL:-}" ]]; then
    echo "[ERROR] Received $TERMINATION_SIGNAL."
  fi
  if [[ -n "${DRIVER_RC:-}" ]]; then
    echo "[INFO] Driver exit code: $DRIVER_RC"
  fi
  echo "[INFO] Cleaning up Ray processes..."
  for pid in "${SRUN_PIDS[@]:-}"; do
    kill "$pid" >/dev/null 2>&1 || true
  done
  for node in "${nodes[@]:-}"; do
    srun --overlap -N1 -n1 -w "$node" "$RAY_BIN" stop --force >/dev/null 2>&1 || true
  done
  return "$rc"
}
trap cleanup EXIT
trap 'TERMINATION_SIGNAL="SIGINT"; exit 130' INT
trap 'TERMINATION_SIGNAL="SIGTERM"; exit 143' TERM

get_node_ip() {
  local node="$1"
  if [[ -n "${NETWORK_IFACE:-}" ]]; then
    srun --overlap -N1 -n1 -w "$node" \
      bash -lc "ip -4 -o addr show dev '$NETWORK_IFACE' | awk '{split(\$4, a, \"/\"); print a[1]; exit}'" \
      2>/dev/null || true
  else
    srun --overlap -N1 -n1 -w "$node" \
      bash -lc "hostname -I | awk '{print \$1}'" \
      2>/dev/null || true
  fi
}

if [[ -n "${NETWORK_IFACE:-}" ]]; then
  export GLOO_SOCKET_IFNAME="${GLOO_SOCKET_IFNAME:-$NETWORK_IFACE}"
  export NCCL_SOCKET_IFNAME="${NCCL_SOCKET_IFNAME:-$NETWORK_IFACE}"
fi
export NCCL_IB_DISABLE="${NCCL_IB_DISABLE:-0}"
export NCCL_DEBUG="${NCCL_DEBUG:-WARN}"

echo "[INFO] Job $SLURM_JOB_ID: ${#nodes[@]} node(s): ${nodes[*]}"
echo "[INFO] GPUs/node: $GPUS_PER_NODE  CPUs/worker: $CPUS_PER_WORKER"

declare -A NODE_IPS=()
for node in "${nodes[@]}"; do
  ip="$(get_node_ip "$node")"
  if [[ -z "$ip" ]]; then
    echo "[ERROR] Could not resolve IPv4 for $node"
    exit 1
  fi
  NODE_IPS["$node"]="$ip"
  echo "[INFO] $node -> $ip"
done

for node in "${nodes[@]}"; do
  srun --overlap -N1 -n1 -w "$node" "$RAY_BIN" stop --force >/dev/null 2>&1 || true
done

head_ip="${NODE_IPS[$head_node]}"
head_addr="${head_ip}:$RAY_PORT"

echo "[INFO] Starting Ray head on $head_node ($head_ip)"
srun --overlap -N1 -n1 -w "$head_node" -o "$LOG_DIR/ray-head.log" \
  "$RAY_BIN" start --head \
  --temp-dir="$RAY_TMPDIR" \
  --node-ip-address="$head_ip" \
  --port="$RAY_PORT" \
  --dashboard-port="$RAY_DASHBOARD_PORT" \
  --dashboard-host="$head_ip" \
  --num-cpus="$CPUS_PER_WORKER" \
  --num-gpus="$GPUS_PER_NODE" \
  --object-store-memory="$RAY_OBJECT_STORE_MEMORY" \
  --resources="{\"worker_units\": $GPUS_PER_NODE, \"slurm_managed_ray_cluster\": 1}" \
  --disable-usage-stats \
  --block &
SRUN_PIDS+=($!)

echo "[INFO] Waiting for Ray head at $head_addr..."
for attempt in $(seq 1 30); do
  if ! kill -0 "${SRUN_PIDS[0]}" >/dev/null 2>&1; then
    echo "[ERROR] Ray head exited unexpectedly. Check $LOG_DIR/ray-head.log"
    exit 1
  fi
  if srun --overlap -N1 -n1 -w "$head_node" "$RAY_BIN" status --address "$head_addr" >/dev/null 2>&1; then
    echo "[INFO] Ray head reachable"
    break
  fi
  if [[ "$attempt" -eq 30 ]]; then
    echo "[ERROR] Timed out waiting for Ray head at $head_addr"
    exit 1
  fi
  sleep 2
done

for ((i = 1; i < ${#nodes[@]}; i++)); do
  worker="${nodes[$i]}"
  worker_ip="${NODE_IPS[$worker]}"
  echo "[INFO] Starting Ray worker on $worker ($worker_ip)"
  srun --overlap -N1 -n1 -w "$worker" -o "$LOG_DIR/ray-worker-$i.log" \
    "$RAY_BIN" start \
    --temp-dir="$RAY_TMPDIR" \
    --address "$head_addr" \
    --node-ip-address="$worker_ip" \
    --num-cpus="$CPUS_PER_WORKER" \
    --num-gpus="$GPUS_PER_NODE" \
    --object-store-memory="$RAY_OBJECT_STORE_MEMORY" \
    --resources="{\"worker_units\": $GPUS_PER_NODE, \"slurm_managed_ray_cluster\": 1}" \
    --disable-usage-stats \
    --block &
  SRUN_PIDS+=($!)
  sleep 2
done

extract_worker_units() {
  local status_output
  status_output="$(srun --overlap -N1 -n1 -w "$head_node" "$RAY_BIN" status --address "$head_addr" 2>&1 || true)"
  printf '%s\n' "$status_output" >> "$LOG_DIR/ray-status.log"
  awk '
    /worker_units/ {
      if (match($0, /[0-9]+(\.[0-9]+)?\/[0-9]+(\.[0-9]+)?/)) {
        split(substr($0, RSTART, RLENGTH), a, "/");
        print int(a[2] + 0);
        found = 1;
        exit
      }
    }
    END { if (!found) print 0 }' <<< "$status_output"
}

EXPECTED_WORKER_UNITS=$((GPUS_PER_NODE * SLURM_JOB_NUM_NODES))
echo "[INFO] Waiting for worker_units=$EXPECTED_WORKER_UNITS..."
for attempt in $(seq 1 60); do
  ACTIVE="$(extract_worker_units)"
  echo "[INFO] [$attempt/60] worker_units: $ACTIVE/$EXPECTED_WORKER_UNITS"
  if [[ "$ACTIVE" -eq "$EXPECTED_WORKER_UNITS" ]]; then
    echo "[INFO] All workers connected"
    break
  fi
  if [[ "$attempt" -eq 60 ]]; then
    echo "[ERROR] Timed out waiting for Ray workers"
    exit 1
  fi
  sleep 5
done

COMMAND="${COMMAND:-}"
if [[ -n "$COMMAND" ]]; then
  echo "[INFO] Running: $COMMAND"
  set +e
  cd "$REPO_ROOT"
  eval "$COMMAND" > "$LOG_DIR/ray-driver.log" 2>&1
  DRIVER_RC=$?
  set -e
  echo "=== Driver log (last 100 lines) ==="
  tail -100 "$LOG_DIR/ray-driver.log" 2>/dev/null || true
  if [[ "$DRIVER_RC" -ne 0 ]]; then
    echo "[ERROR] Driver failed with exit code $DRIVER_RC"
  fi
  exit "$DRIVER_RC"
fi

echo "[INFO] No COMMAND specified. Ray cluster is idle."
echo "[INFO] Attach: srun --overlap --jobid $SLURM_JOB_ID -N1 -n1 -w $head_node --pty bash"
sleep infinity
